# Backend environment template. Copy to .env and set values. Never commit .env.
# Required: MONGODB_URI, JWT_SECRET. Optional: all others (defaults in code or below).

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/musaed
# Connection pool (optional, for horizontal scaling)
MONGODB_MAX_POOL_SIZE=
MONGODB_MIN_POOL_SIZE=

# Server
NODE_ENV=development
PORT=3001

# CORS (comma-separated origins). Default in code includes 5173 + 3002 (prototype dev port).
# ALLOWED_ORIGINS takes precedence over CORS_ORIGIN
ALLOWED_ORIGINS=
CORS_ORIGIN=http://localhost:5173,http://localhost:3002

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_generate_a_secure_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ). Comment out REDIS_URL locally if you do not run Redis (queues fall back to inline/sync).
# Production: set REDIS_URL and enable the queues you need (webhooks, email, notifications, agent deploy).
REDIS_URL=redis://localhost:6379
AGENT_DEPLOYMENT_QUEUE_ENABLED=false
QUEUE_WEBHOOKS_ENABLED=false
QUEUE_EMAIL_ENABLED=false
QUEUE_NOTIFICATIONS_ENABLED=false
QUEUE_DEPTH_LOGGING_ENABLED=false
# Example production-style flags (requires REDIS_URL):
# AGENT_DEPLOYMENT_QUEUE_ENABLED=true
# QUEUE_WEBHOOKS_ENABLED=true
# QUEUE_EMAIL_ENABLED=true
# QUEUE_NOTIFICATIONS_ENABLED=true

# Stripe (billing) — use test keys during development
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Legacy secret for zero-downtime rotation (optional)
STRIPE_WEBHOOK_SECRET_LEGACY=

# Email — Gmail SMTP (required for invite and forgot-password emails)
# Without these, no emails are sent (only logged in dev). Use Gmail App Password:
# https://myaccount.google.com/apppasswords — not your normal Gmail password.
# For testing: set owner email to the recipient (e.g. callthor123@gmail.com) when creating a tenant.
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@musaed.app

# Multi-transport: primary and fallback SMTP (optional)
# Falls back to SMTP_USER/SMTP_PASS if not set
SMTP_PRIMARY_USER=
SMTP_PRIMARY_PASS=
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=

# Per-recipient rate limit (emails per hour, 0 = disabled)
EMAIL_RATE_LIMIT_PER_RECIPIENT=10

# Admin SMTP test: POST /api/test-email (requires Admin JWT). Keep false in production.
ENABLE_TEST_EMAIL=false
# Optional default recipient when body omits `to`
TEST_EMAIL_RECIPIENT=

# SendGrid removed — using nodemailer SMTP directly

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Retell (voice/chat agents). Omit RETELL_API_KEY to run API without Retell; health shows retell: skipped.
# For deployments and tools, set a valid key.
RETELL_API_KEY=key_xxx
#
# Webhook URLs (global prefix is /api EXCEPT these — register in Retell/Stripe/Cal.com WITHOUT /api):
#   https://YOUR_HOST/webhooks/retell
#   https://YOUR_HOST/webhooks/stripe
#   https://YOUR_HOST/webhooks/calcom
#
# Optional webhook signature secret for /webhooks/retell (reject unsigned requests when set)
RETELL_WEBHOOK_SECRET=retell_whsec_xxx
# Legacy secret for zero-downtime rotation (optional)
RETELL_WEBHOOK_SECRET_LEGACY=
# Replay protection: max age of x-retell-timestamp in seconds (0 = disabled locally; use e.g. 600 in production)
WEBHOOK_TIMESTAMP_MAX_AGE_SEC=0
# Public base URL for Retell custom tools (must be reachable by Retell servers, e.g. ngrok or prod API)
API_BASE_URL=http://localhost:3001
# Shared API key for Retell tool callbacks into backend
RETELL_TOOL_API_KEY=CHANGE_ME_retell_tool_key
# Feature flags for phased rollout and migration safety
AGENT_DEPLOYMENT_V2_ENABLED=true
AGENT_AUTO_DEPLOY_ON_CREATE=true
# Alert threshold for deployment failure rate (0-1)
AGENT_DEPLOYMENT_FAILURE_ALERT_THRESHOLD=0.3
# Call-session ingestion from Retell webhooks
CALL_SESSION_INGEST_ENABLED=true

# Cal.com — HMAC secret for POST /webhooks/calcom (same host as API; path has no /api prefix)
CALCOM_WEBHOOK_SECRET=

# Seed script — required when running `npm run seed`
# Admin: admin@musaed.com | Owner: owner@democlinic.com
# To reset admin password: set ADMIN_SEED_PASSWORD here, then run node reset-admin-password.js
ADMIN_SEED_PASSWORD=
OWNER_SEED_PASSWORD=

# Report pre-aggregation (daily cron at 2 AM)
REPORT_AGGREGATION_ENABLED=false

# Optional: real-infrastructure validation scripts (`npm run validate:infra`, `npm run validate:infra:smoke`)
# Precheck uses SMOKE_BASE_URL or API_BASE_URL for GET /health (default http://localhost:3001).
# SMOKE_BASE_URL=
# API_BASE_URL=
# ALLOW_DEGRADED_HEALTH=false
# Smoke API (requires running server + seeded users):
# SMOKE_ADMIN_EMAIL=
# SMOKE_ADMIN_PASSWORD=
# SMOKE_TENANT_EMAIL=
# SMOKE_TENANT_PASSWORD=
# SMOKE_AGENT_INSTANCE_ID=

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Metrics endpoint protection (optional; open when unset)
METRICS_API_KEY=
