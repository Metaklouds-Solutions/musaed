# MongoDB
MONGODB_URI=mongodb://localhost:27017/musaed

# Server
PORT=3001

# CORS (comma-separated origins for production)
CORS_ORIGIN=http://localhost:5173

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_generate_a_secure_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (optional, for sessions/cache)
REDIS_URL=redis://localhost:6379
AGENT_DEPLOYMENT_QUEUE_ENABLED=false

# Stripe (billing) — use test keys during development
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email — Gmail SMTP (required for invite and forgot-password emails)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@musaed.app

# SendGrid (alternative, if not using Gmail SMTP)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@musaed.app

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Retell (agent deployment)
RETELL_API_KEY=key_xxx
# Optional webhook signature secret for /webhooks/retell
RETELL_WEBHOOK_SECRET=retell_whsec_xxx
# Legacy secret for zero-downtime rotation (optional)
RETELL_WEBHOOK_SECRET_LEGACY=
# Replay protection: max age of x-retell-timestamp in seconds (0 = disabled)
WEBHOOK_TIMESTAMP_MAX_AGE_SEC=0
# Base URL used to resolve tool endpoints in flow templates
API_BASE_URL=http://localhost:3001
# Shared API key for Retell tool callbacks into backend
RETELL_TOOL_API_KEY=CHANGE_ME_retell_tool_key
# Feature flags for phased rollout and migration safety
AGENT_DEPLOYMENT_V2_ENABLED=true
AGENT_AUTO_DEPLOY_ON_CREATE=true
# Alert threshold for deployment failure rate (0-1)
AGENT_DEPLOYMENT_FAILURE_ALERT_THRESHOLD=0.3
# Call-session ingestion from Retell webhooks
CALL_SESSION_INGEST_ENABLED=true

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
